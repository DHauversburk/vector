# Project Vector — local environment variables
# Copy this file to .env.local (NOT .env — see docs/SEC-001-env-in-git.md)
# and populate with staging credentials. Ask the repo admin for values.
#
# For the authoritative per-environment matrix (local / CI / preview / staging /
# production) see docs/ENVIRONMENTS.md.

# --- Supabase (frontend) ---
# Exposed to the client build. Safe to expose: RLS enforces access.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<paste_staging_anon_key_here>

# --- App metadata ---
VITE_APP_NAME="VECTOR"

# --- Mock mode toggle ---
# Set VITE_FORCE_MOCK=true to run the app against the in-memory mock client in
# src/lib/supabase.ts (useful for offline development / demos).
# Leave UNSET or false to connect to real Supabase.
#
# NOTE: Sprint 14 / P4 renames this to VITE_MOCK_MODE and adds a production
# build guard that aborts startup if mock mode is enabled in a prod build.
# See docs/ENTERPRISE_ROADMAP.md §8 Risk #1.
VITE_FORCE_MOCK=false

# --- Feature flags (Sprint 15+ rollout) ---
# See docs/ENTERPRISE_ROADMAP.md §8 Risks #7, #8 for the Epic F rollout plan.
# VITE_UX_V2=false              # flip true after Sprint 16 visual-regression passes
# VITE_LEGACY_ONBOARDING=false  # flip true to fall back to the legacy tour

# --- Observability (Sprint 18 / P6) ---
# VITE_SENTRY_DSN=<dev_or_staging_dsn>
#
# Server-side secrets NEVER belong here (no VITE_ prefix):
#   SUPABASE_SERVICE_ROLE_KEY — Supabase Functions secrets only
#   SUPABASE_FUNCTION_PEPPER  — Supabase Functions secrets only
# See docs/ENVIRONMENTS.md §Scoping for how to set these.
